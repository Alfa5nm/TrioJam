[sub_resource type="Shader" id="FilmShader"]
code = "shader_type canvas_item;\nuniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_linear;\nuniform float grain_strength : hint_range(0.0, 0.2) = 0.035;\nuniform float scanline_strength : hint_range(0.0, 0.2) = 0.045;\nfloat hash(vec2 p){ return fract(sin(dot(p, vec2(12.9898,78.233))) * 43758.5453); }\nvoid fragment(){\n vec4 c = texture(screen_texture, SCREEN_UV);\n float grain = (hash(UV * vec2(1280.0,720.0) + TIME * 41.0) - 0.5) * grain_strength;\n float scan = sin(UV.y * 720.0 * 3.14159) * scanline_strength;\n COLOR = vec4(c.rgb + grain - scan, c.a);\n}"

[sub_resource type="ShaderMaterial" id="FilmMaterial"]
shader = SubResource("FilmShader")

[sub_resource type="Shader" id="CreditsCRTShader"]
code = "shader_type canvas_item;\nfloat hash(vec2 p){ return fract(sin(dot(p, vec2(12.9898,78.233))) * 43758.5453); }\nvoid fragment(){\n vec2 q = UV - 0.5;\n float scan = (sin(UV.y * 720.0 * 3.14159265) * 0.5 + 0.5) * 0.105;\n float noise = (hash(floor(UV * vec2(640.0,360.0)) + floor(TIME * 24.0)) - 0.5) * 0.032;\n float vignette = smoothstep(0.34, 0.72, length(q * vec2(0.9, 1.0))) * 0.42;\n float alpha = clamp(0.035 + scan + vignette + max(noise, 0.0), 0.0, 0.58);\n COLOR = vec4(0.005, 0.008, 0.025, alpha);\n}"

[sub_resource type="ShaderMaterial" id="CreditsCRTMaterial"]
shader = SubResource("CreditsCRTShader")

[sub_resource type="Shader" id="CreditsTextFadeShader"]
code = "shader_type canvas_item;\nuniform float transparent_until : hint_range(0.0, 1.0) = 0.30;\nuniform float fully_visible_from : hint_range(0.0, 1.0) = 0.46;\nvoid fragment(){\n float title_clearance_mask = smoothstep(transparent_until, fully_visible_from, SCREEN_UV.y);\n COLOR.a *= title_clearance_mask;\n}"

[sub_resource type="ShaderMaterial" id="CreditsTextFadeMaterial"]
shader = SubResource("CreditsTextFadeShader")


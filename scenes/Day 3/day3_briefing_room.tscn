[sub_resource type="Shader" id="StressShader"]
code = "shader_type canvas_item;\nuniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_linear;\nvoid fragment(){ vec2 p=UV-vec2(0.5); float edge=smoothstep(0.12,0.72,length(p)); vec2 split=vec2(0.0035*edge,0.0); vec3 c; c.r=texture(screen_texture,SCREEN_UV+split).r; c.g=texture(screen_texture,SCREEN_UV).g; c.b=texture(screen_texture,SCREEN_UV-split).b; c=mix(c,vec3(0.18,0.01,0.08),0.18*edge); COLOR=vec4(c,1.0); }"

[sub_resource type="ShaderMaterial" id="StressMaterial"]

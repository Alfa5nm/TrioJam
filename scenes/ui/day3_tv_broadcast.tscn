code = "shader_type canvas_item;
float hash(vec2 p){return fract(sin(dot(p,vec2(12.9898,78.233)))*43758.5453);}
void fragment(){float line=sin(UV.y*360.0*3.14159)*0.045;float noise=(hash(UV*vec2(640.0,360.0)+TIME*31.0)-0.5)*0.06;COLOR=vec4(vec3(noise-line),0.11); }"


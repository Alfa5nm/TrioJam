[sub_resource type="Shader" id="crt_shader"]
code = "shader_type canvas_item;

uniform float boot_progress : hint_range(0.0, 1.0) = 1.0;
uniform float scanline_strength : hint_range(0.0, 0.3) = 0.075;
uniform float chromatic_offset : hint_range(0.0, 0.01) = 0.0018;
uniform float vignette_strength : hint_range(0.0, 1.0) = 0.32;

float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453); }

void fragment() {
    vec2 uv = UV;
    vec2 centered = uv * 2.0 - 1.0;
    float bend = dot(centered, centered) * 0.035;
    uv = (centered * (1.0 + bend) + 1.0) * 0.5;
    float inside = step(0.0, uv.x) * step(uv.x, 1.0) * step(0.0, uv.y) * step(uv.y, 1.0);
    vec4 base = texture(TEXTURE, uv);
    float r = texture(TEXTURE, uv + vec2(chromatic_offset, 0.0)).r;
    float b = texture(TEXTURE, uv - vec2(chromatic_offset, 0.0)).b;
    base.rgb = vec3(r, base.g, b);
    float scan = sin(uv.y * 900.0) * 0.5 + 0.5;
    base.rgb *= 1.0 - scan * scanline_strength;
    base.rgb += (hash(uv + TIME * 0.03) - 0.5) * 0.025;
    float vignette = 1.0 - dot(centered * 0.65, centered * 0.65) * vignette_strength;
    float line_half = mix(0.004, 0.57, smoothstep(0.0, 0.78, boot_progress));
    float boot_mask = smoothstep(line_half + 0.018, line_half, abs(uv.y - 0.5));
    float white_line = (1.0 - smoothstep(0.002, 0.014, abs(uv.y - 0.5))) * (1.0 - smoothstep(0.0, 0.3, boot_progress));
    base.rgb = base.rgb * boot_mask * vignette + vec3(0.72, 0.94, 1.0) * white_line;
    COLOR = vec4(base.rgb, base.a * inside);
}"


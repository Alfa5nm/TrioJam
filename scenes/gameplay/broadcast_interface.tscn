[sub_resource type="Shader" id="crt_shader"]
code = "shader_type canvas_item;\n\nuniform float boot_progress : hint_range(0.0, 1.0) = 1.0;\nuniform float scanline_strength : hint_range(0.0, 0.3) = 0.075;\nuniform float chromatic_offset : hint_range(0.0, 0.01) = 0.0018;\nuniform float vignette_strength : hint_range(0.0, 1.0) = 0.32;\n\nfloat hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453); }\n\nvoid fragment() {\n    vec2 uv = UV;\n    vec2 centered = uv * 2.0 - 1.0;\n    float bend = dot(centered, centered) * 0.035;\n    uv = (centered * (1.0 + bend) + 1.0) * 0.5;\n    float inside = step(0.0, uv.x) * step(uv.x, 1.0) * step(0.0, uv.y) * step(uv.y, 1.0);\n    vec4 base = texture(TEXTURE, uv);\n    float r = texture(TEXTURE, uv + vec2(chromatic_offset, 0.0)).r;\n    float b = texture(TEXTURE, uv - vec2(chromatic_offset, 0.0)).b;\n    base.rgb = vec3(r, base.g, b);\n    float scan = sin(uv.y * 900.0) * 0.5 + 0.5;\n    base.rgb *= 1.0 - scan * scanline_strength;\n    base.rgb += (hash(uv + TIME * 0.03) - 0.5) * 0.025;\n    float vignette = 1.0 - dot(centered * 0.65, centered * 0.65) * vignette_strength;\n    float line_half = mix(0.004, 0.57, smoothstep(0.0, 0.78, boot_progress));\n    float boot_mask = smoothstep(line_half + 0.018, line_half, abs(uv.y - 0.5));\n    float white_line = (1.0 - smoothstep(0.002, 0.014, abs(uv.y - 0.5))) * (1.0 - smoothstep(0.0, 0.3, boot_progress));\n    base.rgb = base.rgb * boot_mask * vignette + vec3(0.72, 0.94, 1.0) * white_line;\n    COLOR = vec4(base.rgb, base.a * inside);\n}"


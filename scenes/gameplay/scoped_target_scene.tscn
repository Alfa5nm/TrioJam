[sub_resource type="Shader" id="Shader_scope_mask"]
code = "shader_type canvas_item;

uniform vec2 viewport_size = vec2(1280.0, 720.0);
uniform vec2 scope_center = vec2(640.0, 360.0);
uniform float scope_radius = 245.0;

void fragment() {
	vec2 pixel = UV * viewport_size;
	float distance_from_scope = distance(pixel, scope_center);
	float outside = smoothstep(scope_radius - 5.0, scope_radius + 5.0, distance_from_scope);
	float glass_edge = smoothstep(scope_radius * 0.72, scope_radius, distance_from_scope);
	float alpha = mix(0.035 + glass_edge * 0.08, 0.67, outside);
	COLOR = vec4(0.006, 0.01, 0.016, alpha);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_scope_mask"]
shader = SubResource("Shader_scope_mask")
shader_parameter/viewport_size = Vector2(1280, 720)
shader_parameter/scope_center = Vector2(640, 360)
shader_parameter/scope_radius = 245.0

[sub_resource type="Shader" id="Shader_scope_vignette"]
code = "shader_type canvas_item;

void fragment() {
	vec2 centered = UV * 2.0 - 1.0;
	centered.x *= 1.18;
	float radius = length(centered);
	float edge = smoothstep(0.42, 1.28, radius);
	float hard_corner = smoothstep(0.88, 1.36, radius);
	COLOR = vec4(0.004, 0.006, 0.012, edge * 0.34 + hard_corner * 0.28);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_scope_vignette"]
shader = SubResource("Shader_scope_vignette")


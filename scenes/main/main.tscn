[sub_resource type="Shader" id="Shader_props_cleanup"]
code = "shader_type canvas_item;\n\nvoid fragment() {\n\tvec4 pixel = texture(TEXTURE, UV);\n\tfloat brightest = max(pixel.r, max(pixel.g, pixel.b));\n\tfloat darkest = min(pixel.r, min(pixel.g, pixel.b));\n\tfloat luminance = dot(pixel.rgb, vec3(0.299, 0.587, 0.114));\n\tbool inside_baked_glow = UV.x > 0.68 && UV.y < 0.56;\n\tbool glow_checker = inside_baked_glow && luminance > 0.30 && luminance < 0.82 && (brightest - darkest) < 0.28;\n\tif (glow_checker) {\n\t\tpixel.a = 0.0;\n\t}\n\tCOLOR = pixel * COLOR;\n}\n"


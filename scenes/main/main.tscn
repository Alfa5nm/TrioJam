[sub_resource type="Shader" id="Shader_checker_cleanup"]
code = "shader_type canvas_item;\n\nvoid fragment() {\n\tvec4 pixel = texture(TEXTURE, UV);\n\tfloat brightest = max(pixel.r, max(pixel.g, pixel.b));\n\tfloat darkest = min(pixel.r, min(pixel.g, pixel.b));\n\tbool neutral_checker = darkest > 0.70 && (brightest - darkest) < 0.09;\n\tif (neutral_checker) {\n\t\tpixel.a = 0.0;\n\t}\n\tCOLOR = pixel * COLOR;\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_checker_cleanup"]

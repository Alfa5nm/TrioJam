[sub_resource type="Shader" id="Shader_volumetric_beam"]
code = "shader_type canvas_item;
render_mode blend_add;

void fragment() {
	float lateral = 1.0 - abs(UV.x - 0.5) * 2.0;
	float soft_edge = smoothstep(0.0, 0.72, lateral);
	float depth_fade = smoothstep(0.0, 0.16, UV.y) * (1.0 - UV.y * 0.52);
	COLOR = vec4(COLOR.rgb, COLOR.a * soft_edge * depth_fade);
}
"


[sub_resource type="Shader" id="Shader_crt"]
code = "shader_type canvas_item;\nuniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_linear;\nuniform float curvature : hint_range(0.0, 0.08) = 0.018;\nuniform float scanline_strength : hint_range(0.0, 0.3) = 0.12;\nuniform float noise_strength : hint_range(0.0, 0.12) = 0.025;\nuniform float aberration : hint_range(0.0, 0.01) = 0.0015;\nfloat hash(vec2 p){ return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }\nvoid fragment(){\n vec2 uv = SCREEN_UV;\n vec2 centered = uv - 0.5;\n float radius = dot(centered, centered);\n uv += centered * radius * curvature;\n vec2 chroma = vec2(aberration * (0.5 + radius * 2.0), 0.0);\n vec3 col;\n col.r = texture(screen_texture, uv + chroma).r;\n col.g = texture(screen_texture, uv).g;\n col.b = texture(screen_texture, uv - chroma).b;\n float scan = sin(uv.y * 720.0 * 3.14159265) * scanline_strength;\n float fine_scan = sin(uv.y * 1080.0 * 3.14159265) * 0.025;\n float noise = (hash(floor(uv * vec2(640.0, 360.0)) + floor(TIME * 24.0)) - 0.5) * noise_strength;\n float vignette = smoothstep(0.82, 0.18, length(centered * vec2(0.88, 1.0)));\n float flicker = 0.985 + sin(TIME * 53.0) * 0.006;\n col = (col - scan - fine_scan + noise) * flicker * mix(0.72, 1.0, vignette);\n if(uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0){ col = vec3(0.0); }\n COLOR = vec4(col, 1.0);\n}"

